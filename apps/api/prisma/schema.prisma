generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  ADMIN
  CASHIER
  WAITER
  KITCHEN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  SALE
  PAYOUT
  DROP
  REFUND
  ADJUSTMENT
  CLOSING
}

enum OrderType {
  COUNTER
  TABLE
  DELIVERY
}

enum OrderStatus {
  OPEN
  SUBMITTED
  IN_PREPARATION
  READY
  DELIVERED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum KitchenTicketStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  PENDING_PAYMENT
}

enum UnitOfMeasure {
  UNIT
  GRAM
  KILOGRAM
  MILLILITER
  LITER
  PORTION
}

enum StockMovementType {
  PURCHASE
  CONSUMPTION
  ADJUSTMENT
  WASTE
  RETURN
}

enum AuditAction {
  LOGIN
  CREATE
  UPDATE
  DELETE
  OPEN_REGISTER
  CLOSE_REGISTER
  CREATE_ORDER
  SEND_TO_KITCHEN
  COMPLETE_PAYMENT
  UPDATE_KITCHEN_STATUS
  ADJUST_STOCK
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  passwordHash             String                    @map("password_hash")
  firstName                String                    @map("first_name")
  lastName                 String                    @map("last_name")
  displayName              String                    @map("display_name")
  status                   UserStatus                @default(ACTIVE)
  isActive                 Boolean                   @default(true) @map("is_active")
  lastLoginAt              DateTime?                 @map("last_login_at")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  roles                    UserRole[]
  auditLogs                AuditLog[]
  openedRegisters          CashRegister[]            @relation("OpenedRegisters")
  closedRegisters          CashRegister[]            @relation("ClosedRegisters")
  cashMovements            CashMovement[]
  placedOrders             Order[]                   @relation("PlacedOrders")
  receivedPayments         Payment[]                 @relation("ReceivedPayments")
  ingredientStockMovements IngredientStockMovement[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  code        RoleCode         @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model CashRegister {
  id                 String              @id @default(uuid())
  label              String
  status             CashRegisterStatus  @default(OPEN)
  openingAmount      Decimal             @default(0) @db.Decimal(10, 2) @map("opening_amount")
  expectedAmount     Decimal             @default(0) @db.Decimal(10, 2) @map("expected_amount")
  countedAmount      Decimal?            @db.Decimal(10, 2) @map("counted_amount")
  salesCashAmount    Decimal             @default(0) @db.Decimal(10, 2) @map("sales_cash_amount")
  salesCardAmount    Decimal             @default(0) @db.Decimal(10, 2) @map("sales_card_amount")
  salesTransferAmount Decimal            @default(0) @db.Decimal(10, 2) @map("sales_transfer_amount")
  notes              String?
  openedAt           DateTime            @default(now()) @map("opened_at")
  closedAt           DateTime?           @map("closed_at")
  openedById         String              @map("opened_by_id")
  closedById         String?             @map("closed_by_id")
  cashMovements      CashMovement[]
  orders             Order[]
  openedBy           User                @relation("OpenedRegisters", fields: [openedById], references: [id])
  closedBy           User?               @relation("ClosedRegisters", fields: [closedById], references: [id])
  payments           Payment[]

  @@map("cash_registers")
}

model CashMovement {
  id             String            @id @default(uuid())
  cashRegisterId String            @map("cash_register_id")
  createdById    String            @map("created_by_id")
  type           CashMovementType
  amount         Decimal           @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?    @map("payment_method")
  reason         String?
  referenceId    String?           @map("reference_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  cashRegister   CashRegister      @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  createdBy      User              @relation(fields: [createdById], references: [id])

  @@map("cash_movements")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id              String          @id @default(uuid())
  sku             String          @unique
  name            String
  description     String?
  price           Decimal         @db.Decimal(10, 2)
  estimatedCost   Decimal         @default(0) @db.Decimal(10, 2) @map("estimated_cost")
  isAvailable     Boolean         @default(true) @map("is_available")
  notesEnabled    Boolean         @default(true) @map("notes_enabled")
  categoryId      String          @map("category_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  category        Category        @relation(fields: [categoryId], references: [id])
  recipes         ProductRecipe[]
  orderItems      OrderItem[]

  @@map("products")
}

model Ingredient {
  id             String                    @id @default(uuid())
  sku            String?                   @unique
  name           String                    @unique
  unit           UnitOfMeasure
  currentStock   Decimal                   @default(0) @db.Decimal(12, 3) @map("current_stock")
  minimumStock   Decimal                   @default(0) @db.Decimal(12, 3) @map("minimum_stock")
  costPerUnit    Decimal                   @default(0) @db.Decimal(10, 4) @map("cost_per_unit")
  isActive       Boolean                   @default(true) @map("is_active")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  recipes        ProductRecipe[]
  stockMovements IngredientStockMovement[]

  @@map("ingredients")
}

model ProductRecipe {
  id           String     @id @default(uuid())
  productId    String     @map("product_id")
  ingredientId String     @map("ingredient_id")
  quantity     Decimal    @db.Decimal(12, 3)
  createdAt    DateTime   @default(now()) @map("created_at")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@map("product_recipes")
}

model IngredientStockMovement {
  id           String            @id @default(uuid())
  ingredientId String            @map("ingredient_id")
  createdById  String?           @map("created_by_id")
  type         StockMovementType
  quantity     Decimal           @db.Decimal(12, 3)
  balanceAfter Decimal           @db.Decimal(12, 3) @map("balance_after")
  referenceId  String?           @map("reference_id")
  referenceType String?          @map("reference_type")
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at")
  ingredient   Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  createdBy    User?             @relation(fields: [createdById], references: [id])

  @@map("ingredient_stock_movements")
}

model DiningTable {
  id        String      @id @default(uuid())
  name      String      @unique
  area      String?
  seats     Int         @default(2)
  status    TableStatus @default(AVAILABLE)
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  orders    Order[]

  @@map("tables")
}

model Order {
  id             String       @id @default(uuid())
  orderNumber    String       @unique @map("order_number")
  type           OrderType
  status         OrderStatus  @default(OPEN)
  tableId        String?      @map("table_id")
  registerId     String?      @map("register_id")
  placedById     String       @map("placed_by_id")
  parentOrderId  String?      @map("parent_order_id")
  customerName   String?      @map("customer_name")
  notes          String?
  subtotal       Decimal      @default(0) @db.Decimal(10, 2)
  discountAmount Decimal      @default(0) @db.Decimal(10, 2) @map("discount_amount")
  taxAmount      Decimal      @default(0) @db.Decimal(10, 2) @map("tax_amount")
  totalAmount    Decimal      @default(0) @db.Decimal(10, 2) @map("total_amount")
  submittedAt    DateTime?    @map("submitted_at")
  paidAt         DateTime?    @map("paid_at")
  closedAt       DateTime?    @map("closed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  register       CashRegister? @relation(fields: [registerId], references: [id])
  table          DiningTable? @relation(fields: [tableId], references: [id])
  placedBy       User         @relation("PlacedOrders", fields: [placedById], references: [id])
  parentOrder    Order?       @relation("OrderSplits", fields: [parentOrderId], references: [id])
  splitOrders    Order[]      @relation("OrderSplits")
  items          OrderItem[]
  payments       Payment[]
  kitchenTicket  KitchenTicket?

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2) @map("unit_price")
  lineTotal  Decimal  @db.Decimal(10, 2) @map("line_total")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String        @map("order_id")
  cashRegisterId String?       @map("cash_register_id")
  receivedById   String        @map("received_by_id")
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  reference      String?
  createdAt      DateTime      @default(now()) @map("created_at")
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])
  receivedBy     User          @relation("ReceivedPayments", fields: [receivedById], references: [id])

  @@map("payments")
}

model KitchenTicket {
  id          String              @id @default(uuid())
  orderId     String              @unique @map("order_id")
  status      KitchenTicketStatus @default(PENDING)
  sentAt      DateTime            @default(now()) @map("sent_at")
  startedAt   DateTime?           @map("started_at")
  readyAt     DateTime?           @map("ready_at")
  deliveredAt DateTime?           @map("delivered_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("kitchen_tickets")
}

model AuditLog {
  id            String      @id @default(uuid())
  action        AuditAction
  entityType    String      @map("entity_type")
  entityId      String?     @map("entity_id")
  metadata      Json?
  performedById String?     @map("performed_by_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  performedBy   User?       @relation(fields: [performedById], references: [id])

  @@map("audit_logs")
}
